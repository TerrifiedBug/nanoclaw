{
  "mcpServers": {
    "home-assistant": {
      "type": "http",
      "url": "${HA_URL}/api/mcp",
      "headers": {
        "Authorization": "Bearer ${HA_TOKEN}"
      }
    },
    "n8n": {
      "type": "http",
      "url": "${N8N_URL}/mcp",
      "headers": {
        "Authorization": "Bearer ${N8N_API_KEY}"
      }
    }
  }
}
